{
  "expo": {
    "name": "TOMO",
    "slug": "tomo",
    "version": "1.0.1",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "icon": "./assets/fixed-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/TOMO_Logo_1.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f11"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ryanyester.tomo",
      "buildNumber": "9",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/fixed-icon.png",
        "backgroundColor": "#23242f"
      },
      "package": "com.ryanyester.tomo",
      "versionCode": 2
    },
    "extra": {
      "eas": {
        "projectId": "baa2a43e-a568-4f77-96d3-23750b05d5bf"
      }
    },
    "owner": "ryester",
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/fixed-icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ]
  }
}