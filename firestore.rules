rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function removeSpaces(str) {
      return str.replace(" ", "");
    }
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Support collection group queries for album ratings
    match /{path=**}/album_ratings/{ratingId} {
      allow read: if isAuthenticated();
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow update for following/unfollowing (modifies 'followers' on target)
      // For stricter security in future: validate only 'followers' field changes or use Cloud Functions.
      allow update: if isAuthenticated();
      allow create: if isAuthenticated(); // For first login user creation

      // Subcollection: Awards Ballots
      match /awards_ballots/{eventId} {
        allow read, write: if isOwner(userId);
      }

      // Subcollection: Album Ratings (Private User Data)
      match /album_ratings/{ratingId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }

      // Subcollection: Physical Collection
      match /physical_collection/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- CURATIONS (The Corner) ---
    match /curations/{curationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Allow update for 'likes' and 'likedBy' by others
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // --- ALBUMS (Global Ratings & Stats) ---
    match /albums/{albumId} {
      allow read: if isAuthenticated();
      // Allow write to update global stats
      allow write: if isAuthenticated();
      
      // Subcollection: Public User Ratings (for aggregation)
      match /user_ratings/{ratingId} {
         allow read: if isAuthenticated();
         allow write: if isAuthenticated() && request.auth.uid == ratingId;
      }
    }

    // --- POSTS COLLECTION (Legacy / General) ---
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated(); 
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // --- CONNECTIONS COLLECTION (Matched Movie/Music Game) ---
    match /connections/{connectionId} {
      allow create: if isAuthenticated();
      allow read, update: if isAuthenticated() && 
        (request.auth.uid in resource.data.participants || request.auth.uid in request.resource.data.participants);
    }

    // --- AWARD EVENTS COLLECTION ---
    match /award_events/{eventId} {
      allow read, write: if isAuthenticated();
    }
    
    // --- Default Deny ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
